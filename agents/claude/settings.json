{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "refreshInterval": 30
  },
  "permissions": {
    "allow": [
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "Write",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh repo view*)",
      "Bash(gh run view*)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(pwd)"
    ],
    "ask": [
      "Bash(gh pr comment*)",
      "Bash(gh pr create*)",
      "Bash(git checkout .*)",
      "Bash(git clean*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git reset*)"
    ],
    "defaultMode": "auto"
  },
  "skipAutoPermissionPrompt": true
}
